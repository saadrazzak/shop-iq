        "feedbackSuppressed": ".feedback-suppressed",
        "feedbackRater": ".feedback-rater"
      },
      "periods": [
        {
          "period": "30d",
          "stateKey": "oneMonthRatingsData",
          "averageId": "effective-timeperiod-rating-thirty-description"
        },
        {
          "period": "90d",
          "stateKey": "threeMonthRatingsData",
          "averageId": "effective-timeperiod-rating-ninety-description"
        },
        {
          "period": "365d",
          "stateKey": "twelveMonthRatingsData",
          "averageId": "effective-timeperiod-rating-year-description"
        },
        {
          "period": "lifetime",
          "stateKey": "lifetimeRatingsData",
          "averageId": "effective-timeperiod-rating-lifetime-description"
        }
      ]
    },
    "assistant": {
      "searchInputId": "dpx-rex-nile-search-text-input",
      "submitButtonId": "dpx-rex-nile-submit-button-announce",
      "clearButtonSelector": "[data-action-id=\"clear_button_touch\"]",
      "responseSelector": ".rufus-dpx-markdown-content",
      "paragraphSelector": ".rufus-dpx-markdown-paragraph",
      "listBlockSelector": ".rufus-dpx-markdown-list-block",
      "priceHistoryPrompt": "Please provide current product daily price for the last 3 months, format in one paragraph, like \"29 Mar: ₹999, 30 Mar: ₹999, 1 Apr: ₹988..\"",
      "priceHistoryYearlyPrompt": "Please provide current product weekly low price for the last 1 year, format in one paragraph, like \"29 Mar: ₹999, 5 Apr: ₹999, 12 Apr: ₹988..\"",
      "prosConsPrompt": "List exactly 3 pros and 3 cons of this product, each about 4 words. Format as two bullet lists titled 'Pros' and 'Cons'."
    },
    "pageOverlay": {
      "bottomSheet": "[data-testid=\"bottomsheet-box\"]",
      "aspectTabBase": "[data-testid=\"aspect-list\"] [role=\"tab\"]",
      "reviewsContainer": "[data-csa-c-slot-id=\"dp_desktop_customerReviews_feature_div\"]",
      "allPhotosTrigger": "span[data-mix-operations=\"CRSeeMoreThumbnailOpsClickHandler\"]",
      "allPhotosPopover": "[data-action=\"a-popover-a11y\"]",
      "allPhotosPopoverClose": "[data-action=\"a-popover-close\"]"
    }
  },
  "scrapers": {
    "croma": {
      "searchUrl": "https://api.croma.com/searchservices/v1/search",
      "productUrlBase": "https://www.croma.com",
      "params": {
        "currentPage": "0",
        "fields": "FULL",
        "channel": "WEB",
        "channelCode": "400049",
        "spellOpt": "DEFAULT"
      }
    },
    "reliance": {
      "searchUrl": "https://www.reliancedigital.in/ext/search/application/api/v1.0/products",
      "productUrlBase": "https://www.reliancedigital.in/product",
      "applicationId": "645a057875d8c4882b096f7e",
      "companyId": "1"
    },
    "myntra": {
      "searchUrlBase": "https://www.myntra.com",
      "stateVariable": "__myx",
      "stateResultPath": "searchData.results.products"
    },
    "ajio": {
      "searchUrl": "https://www.ajio.com/api/search",
      "productUrlBase": "https://www.ajio.com",
      "params": {
        "fields": "SITE",
        "currentPage": "0"
      }
    },
    "meesho": {
      "searchUrl": "https://www.meesho.com/api/v1/products/search",
      "productUrlBase": "https://www.meesho.com",
      "requestType": "text_search"
    }
  },
  "reddit": {
    "searchUrl": "https://old.reddit.com/search/",
    "oldUrlBase": "https://old.reddit.com",
    "modernUrlBase": "https://www.reddit.com",
    "selectors": {
      "resultContainer": ".search-result-link",
      "titleLink": "a.search-title",
      "subredditLink": "a.search-subreddit-link",
      "score": ".search-score",
      "commentsLink": "a.search-comments",
      "bodyParagraph": ".search-result-body p"
    }
  },
  "youtube": {
    "searchUrl": "https://www.youtube.com/results",
    "watchUrlBase": "https://www.youtube.com/watch?v=",
    "initialDataVariable": "ytInitialData",
    "resultsSectionPath": "contents.twoColumnSearchResultsRenderer.primaryContents.sectionListRenderer.contents",
    "queryTemplates": [
      "{title} review",
      "{title} unboxing"
    ]
  },
  "thresholds": {
    "requestTimeoutMs": 10000,
    "searchResultLimit": 5,
    "reviewScanPageLimit": 2,
    "redditRelevanceMinScore": 0.5,
    "priceHistoryMinPoints": 20,
    "priceHistoryYearlyMinPoints": 6,
    "confidence": {
      "high": 24,
      "medium": 8
    },
    "buyScore": {
      "positive": 75,
      "mixed": 55
    }
  }
}
