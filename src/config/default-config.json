    "urlPatterns": {
      "productPage": "amazon\\.in/(?:[^/]+/)?(?:dp|gp/product|gp/aw/d)/([A-Z0-9]{10})",
      "reviewPage": "amazon\\.in/product-reviews/([A-Z0-9]{10})"
    },
    "reviews": {
      "urlBase": "https://www.amazon.in/product-reviews/",
      "params": {
        "encodingKey": "_encoding",
        "ieKey": "ie",
        "commonValue": "UTF8",
        "pageNumberKey": "pageNumber",
        "reviewerTypeKey": "reviewerType",
        "verifiedValue": "avp_only_reviews",
        "allReviewsValue": "all_reviews",
        "sortKey": "sortBy",
        "recentSortValue": "recent",
        "starFilterKey": "filterByStar",
        "mediaTypeKey": "mediaType",
        "mediaOnlyValue": "media_reviews_only"
      },
      "starFilter": {
        "five": "five_star",
        "four": "four_star",
        "three": "three_star",
        "two": "two_star",
        "one": "one_star"
      }
    },
    "signedOutText": "sign in",
    "seller": {
      "profileUrlBase": "/sp?seller=",
      "linkParamSeller": "seller",
      "linkParamFulfilled": "isAmazonFulfilled",
      "fulfilledValue": "1",
